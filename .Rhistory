)
base1_pct=ggplot(data=ArrestSexDF,
aes(x=`Arrest Type`, y=pctCol,
fill=reorder(Sex,pctCol))) # reordering
barDodge1_pct= base1_pct +  geom_bar(stat="identity",
position ='dodge')+
scale_x_discrete(labels = c(
"M" = "Misdemeanor",
"F" = "Felony",
"W" = "Warrant",
"O" = "Other"
)) +
scale_fill_manual(
values = c(
"F" = "#0072B2",   # Blue
"M" = "#E69F00",   # Orange
"U" = "#009E73"    # Green
),
labels = c(
"F" = "Female",
"M" = "Male",
"U" = "Unknown Gender"
))
common_text_size <- 9.5
common_title_size <-11
barDodge1_pct= barDodge1_pct + labs(title = "Across Genders, Distribution of Arrests is Dominated\nby Misdemeanors",
subtitle = "Arrests by type from January 1, 2019 to March 28, 2020",
x="",
y="Share of all arrests (%)",
fill="",
caption = "Source: Mass-Arrests.xlsx\n44 cases of unknown arrest type excluded from plot") +
theme_classic() +
theme(
legend.position = "bottom",
legend.direction = "horizontal",
plot.title = element_text(
face = "bold",
size = common_title_size
)
) +
theme(
# Axis labels
axis.title.x = element_text(size = common_text_size),
axis.title.y = element_text(size = common_text_size),
# Tick labels
axis.text.x = element_text(size = common_text_size),
axis.text.y = element_text(size = common_text_size),
# Legend text
legend.text = element_text(size = common_text_size),
legend.title = element_text(size = common_text_size)
) +
geom_hline(yintercept = c(20, 40, 60),
linetype = "dashed",
color = "gray70")
#add 44 cases of unkow type exluded from the plot as a note in the caption
barDodge1_pct
saveRDS(barDodge1_pct, file = "plot1.rds")
#box plot to understand age distribution by arrest type without NA
my_data_no_na <- my_data |>
filter(!is.na(`Arrest Type`))
overall_median <- median(my_data_no_na$Age, na.rm = TRUE)
order_levels <- my_data_no_na %>%
group_by(`Arrest Type`) %>%
summarize(median_age = median(Age, na.rm = TRUE)) %>%
arrange(median_age) %>%
pull(`Arrest Type`)
my_data_no_na$`Arrest Type` <- factor(
my_data_no_na$`Arrest Type`,
levels = order_levels
)
boxplot_age = ggplot(my_data_no_na, aes(x = `Arrest Type`, y = Age)) +
geom_boxplot() +
scale_x_discrete(labels = c(
"M" = "Misdemeanor",
"F" = "Felony",
"W" = "Warrant",
"O" = "Other"
)) +
labs(title = "Age Distribution by Arrest Type",
x = "Arrest Type",
y = "Age") +
theme_classic() +
theme(
plot.title = element_text(face = "bold", size = common_title_size),
axis.title.x = element_text(size = common_text_size),
axis.title.y = element_text(size = common_text_size),
axis.text.x = element_text(size = common_text_size),
axis.text.y = element_text(size = common_text_size)
) +
geom_hline(yintercept = overall_median,
linetype = "dashed",
color = "red")
boxplot_age
box_violin <- ggplot(my_data_no_na, aes(x = `Arrest Type`, y = Age)) +
geom_hline(yintercept = c(20, 40, 60, 80),
linetype = "dashed",
color = "gray70") +
geom_hline(yintercept = overall_median,
linetype = "solid",
color = "red") +
geom_violin(fill = "#4FA3D1", alpha = 0.65) +
geom_boxplot(width = 0.1, fill = "white", outlier.shape = NA) +
geom_text(
stat = "summary",
fun = median,
aes(label = round(..y.., 1)),
vjust = -0.7,
size = common_text_size / 3.25) +
annotate("text",
x = .585,
y = overall_median + 1.5,
label = paste("Median\nArrest\nAge =", round(overall_median, 1)),
color = "red",
size = 3) +
scale_x_discrete(labels = c(
"M" = "Misdemeanor",
"F" = "Felony",
"W" = "Warrant",
"O" = "Other"
)) +
labs(
title = "Across All Arrest Types, Arrest Age Distributions Cluster\nin the 20s and 30s",
subtitle = "Median ages are similar across offense types, with only modest variation",
x = "",
y = "Age at Time of Arrest",
caption = "Source: Mass-Arrests.xlsx\n44 cases of unknown arrest type excluded from plot"
) +
theme_classic() +
theme(
plot.title = element_text(face = "bold", size = common_title_size),
axis.title.x = element_text(size = common_text_size),
axis.title.y = element_text(size = common_text_size),
axis.text.x = element_text(size = common_text_size),
axis.text.y = element_text(size = common_text_size)
)
box_violin
saveRDS(box_violin, file = "plot2.rds")
my_data_covid <- read_csv("C:/Users/lgianetti/OneDrive - City of Cambridge/DACSS Program/690V_data_viz/hw-4/covid-19.csv",
col_names = TRUE, col_types = NULL, na = "", skip = 0)
str(my_data_covid, width = 70,strict.width='cut')
#Clean Data
my_data_covid$`Entity` <- factor(my_data_covid$`Entity`)
my_data_covid$`date` <- as.Date(my_data_covid$`date`)
str(my_data_covid, width = 70,strict.width='cut')
summary(my_data_covid) # check for missing values and outliers
#create list of south american countries
south_american_countries <- c(
"Argentina",
"Bolivia",
"Brazil",
"Chile",
"Colombia",
"Ecuador",
"Guyana",
"Paraguay",
"Peru",
"Suriname",
"Uruguay",
"Venezuela"
)
#filter data for south american countries and only for 2020 and remove na values
my_data_covid_sa <- my_data_covid |>
filter(Entity %in% south_american_countries,
year == "2020",
!is.na(daily_cases_mean),
!is.na(daily_deaths_mean)
)
summary(my_data_covid_sa)
#Aggregate the mean cases for each country to ahow Average daily case levels over the year
covid_sa_agg <- my_data_covid_sa |>
group_by(Entity) |>
summarize(mean_daily_cases = mean(daily_cases_mean, na.rm = TRUE),
mean_daily_deaths = mean(daily_deaths_mean, na.rm = TRUE)) |>
arrange(desc(mean_daily_cases))
#adding peru highlight based on findings
covid_sa_agg <- covid_sa_agg |>
mutate(highlight = ifelse(Entity == "Peru", "Peru", "Other"))
covid_sa_agg
#creat a scatterplot
base = ggplot(covid_sa_agg)
vars= base +  aes(x=mean_daily_deaths,y=mean_daily_cases)
geoms=vars + geom_point(aes(color = highlight), size = 2.1)
geoms
#apply log scale to both axes to better visualize the relationship between cases and deaths across countries with very different levels of cases and deaths
geoms_log = geoms +scale_x_log10(
breaks = c(0.1, 1, 10),
labels = c("0.1", "1", "10"),
limits = c(0.1, 10)) +
scale_y_log10(
breaks = c(10, 30, 100),
labels = c("10", "30", "100")
)
geoms_log
cor.test(covid_sa_agg$mean_daily_deaths,covid_sa_agg$mean_daily_cases,method = "pearson")
#add labels to the scatterplot
scat_text = geoms_log +
geom_text_repel(aes(label = Entity, color = highlight), size = 2.8)
scat_text = scat_text +
scale_color_manual(
values = c("Peru" = "firebrick", "Other" = "black")
) +
labs(
title = "Average Daily COVID-19 Cases & Deaths Appear Positively Correlated\nAmong South Americaian Countries in 2020, ",
subtitle = "Peru stands out with high average daily deaths compared to cases",
x = "Average Daily Deaths (log scale)",
y = "Average Daily Cases (log scale)",
caption = "Source: covid-19.csv\nData filtered for 2020 and South American countries only"
) +
theme_classic() +
theme(
legend.position = "none",
plot.title = element_text(face = "bold", size = common_title_size),
axis.title.x = element_text(size = common_text_size),
axis.title.y = element_text(size = common_text_size),
axis.text.x = element_text(size = common_text_size),
axis.text.y = element_text(size = common_text_size)
)
scat_text
saveRDS(scat_text, file = "plot3.rds")
